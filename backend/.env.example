APP_NAME=ExcelAI
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# AI (Phase 3) -- get a free-tier key at https://aistudio.google.com/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Database (Phase 4) -- PostgreSQL. Run locally, e.g.:
#   CREATE ROLE excelai_app WITH LOGIN PASSWORD '...';
#   CREATE DATABASE excelai OWNER excelai_app;
DATABASE_URL=postgresql+psycopg://excelai_app:CHANGE_ME@127.0.0.1:5432/excelai

# Auth (Phase 4) -- generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# Email (Phase 4) -- "console" logs emails instead of sending, no external
# provider required in development
EMAIL_PROVIDER=console
FRONTEND_URL=http://localhost:3000
